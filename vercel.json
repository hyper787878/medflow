{
  "version": 2,
  "builds": [
    { "src": "*.html", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/", "dest": "/medaut-landing.html" },
    { "src": "/metricas", "dest": "/medaut-metricas.html" },
    { "src": "/pacientes", "dest": "/medaut-basededatos.html" },
    { "src": "/virtual", "dest": "/medaut-virtual.html" },
    { "src": "/permisos", "dest": "/medaut-permisos.html" }
  ]
}
